# Zippie Payment Platform - Backend Environment Variables
# NEVER commit a filled-in .env. Use the secrets provider for production.
# Copy this file to .env and update with your actual values.

# Secrets provider: "env" (default, reads os.environ / .env) or "aws"
SECRETS_PROVIDER=env
AWS_REGION=af-south-1
AWS_SECRETS_PREFIX=zippie

# Application
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=Zippie Payment Platform
APP_VERSION=0.1.0

# Observability
SENTRY_DSN=
LOG_FORMAT=json

# Feature flags
FEATURE_TOPUP=true
FEATURE_CASHOUT=false
FEATURE_INTERNAL_P2P=true
FEATURE_PAYNOW_CHECKOUT=true

# Database
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/zippie_db

# JWT
# Generate with: python backend/scripts/generate_secret_key.py
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Paynow Zimbabwe
# Get credentials from https://www.paynow.co.zw
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RETURN_URL=http://localhost:3000/payment/return
PAYNOW_RESULT_URL=http://localhost:8000/api/v1/payments/paynow/webhook

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Risk controls
DAILY_LIMIT_UNVERIFIED=200.0
DAILY_LIMIT_VERIFIED=1000.0

# Admin allowlist (comma-separated emails). Bootstrap path only — see README
# for the role-based access control alternative (users.role = 'admin').
ADMIN_EMAILS=
